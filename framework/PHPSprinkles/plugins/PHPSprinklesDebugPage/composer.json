{
    "name": "phpsprinkles/debug-page",
    "description": "Framework-owned debug status page plugin for PHPSprinkles APIs",
    "license": "proprietary",
    "type": "cakephp-plugin",
    "require": {
        "php": ">=8.2",
        "cakephp/cakephp": "^5.3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5.3 || ^12.1.3"
    },
    "autoload": {
        "psr-4": {
            "PHPSprinklesDebugPage\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPSprinklesDebugPage\\Test\\": "tests/"
        }
    },
    "extra": {
        "installer-name": "PHPSprinklesDebugPage"
    },
    "scripts": {
        "test": "phpunit --colors=always"
    }
}
